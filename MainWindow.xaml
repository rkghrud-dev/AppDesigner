<Window x:Class="AppDesigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppDesigner"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="앱디자이너"
        Width="1680"
        Height="980"
        MinWidth="1360"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Background="#EAE3D6"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFF9F2E8" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#E2D7C6" />
        <SolidColorBrush x:Key="PlainBoardBrush" Color="#FFFFFCF7" />
        <DrawingBrush x:Key="BoardGridBrush" TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute" Stretch="None">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="#FFFFFCF7">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#EAE0D1" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="24,0" EndPoint="24,24" />
                            <LineGeometry StartPoint="0,24" EndPoint="24,24" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <Style x:Key="QuickAddButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="#FFF3EBDE" />
            <Setter Property="BorderBrush" Value="#E1D5C2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,18,0,8" />
            <Setter Property="Foreground" Value="#7C5F41" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="ResizeThumbStyle" TargetType="primitives:Thumb">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#0D7B66" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:Thumb">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryToolButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="#F0E6D7" />
            <Setter Property="BorderBrush" Value="#DDCBB2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="PaletteExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="IsExpanded" Value="True" />
        </Style>
        <Style x:Key="PaletteCardButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="#FFFFFBF5" />
            <Setter Property="BorderBrush" Value="#E1D5C2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#FFF7F0E4" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#D4C4AE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#FFF0E5D4" />
                            </Trigger>
                            <DataTrigger Binding="{Binding DataContext.IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#FFF2E2C9" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#C9923E" />
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top" Padding="8,6" Background="#1F3A5B" Foreground="White">
            <Menu.Resources>
                <Style TargetType="{x:Type MenuItem}">
                    <Setter Property="Foreground" Value="#2B2B2B" />
                    <Setter Property="Background" Value="#FFF9F2E8" />
                </Style>
                <Style x:Key="TopMenuItemStyle" TargetType="{x:Type MenuItem}">
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </Menu.Resources>
            <MenuItem Style="{StaticResource TopMenuItemStyle}" Header="_파일">
                <MenuItem Header="새로 만들기">
                    <MenuItem Header="데스크탑 앱" Tag="desktop" Click="CreateBoardTemplate_OnClick" />
                    <MenuItem Header="렌딩 페이지" Tag="landing" Click="CreateBoardTemplate_OnClick" />
                    <MenuItem Header="휴대폰 앱" Tag="mobile" Click="CreateBoardTemplate_OnClick" />
                    <MenuItem Header="빈 보드" Tag="blank" Click="CreateBoardTemplate_OnClick" />
                </MenuItem>
                <MenuItem Header="작업 파일 열기" Click="LoadWorkspace_OnClick" />
                <MenuItem Header="작업 파일 저장" Click="SaveWorkspace_OnClick" />
                <Separator />
                <MenuItem Header="설계 설명 복사" Click="CopyDesignText_OnClick" />
                <MenuItem Header="보드 이미지를 클립보드로" Click="CopyBoardImage_OnClick" />
                <MenuItem Header="PNG로 저장" Click="SaveBoardPng_OnClick" />
                <Separator />
                <MenuItem Header="종료" Click="Exit_OnClick" />
            </MenuItem>
            <MenuItem Style="{StaticResource TopMenuItemStyle}" Header="_구성요소 추가">
                <MenuItem Header="대화창" Tag="dialog" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="작은 알림창" Tag="popup" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="버튼 묶음" Tag="buttons" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="탭 화면" Tag="tabs" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="리본 탭줄" Tag="ribbontabs" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="리본 명령영역" Tag="ribbonarea" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="리본 그룹" Tag="ribbongroup" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="빠른 실행줄" Tag="quickbar" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="입력 폼" Tag="form" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="화면 구역" Tag="section" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="랜딩 첫 화면" Tag="hero" Click="AddElementMenuItem_OnClick" />
                <MenuItem Header="메모" Tag="note" Click="AddElementMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Style="{StaticResource TopMenuItemStyle}" Header="_특수 기능">
                <MenuItem Header="클립보드 이미지 붙여넣기" Click="PasteReferenceImage_OnClick" />
                <MenuItem Header="붙여넣은 이미지로 기초 도안 만들기" Click="GenerateDraftFromClipboard_OnClick" />
            </MenuItem>
            <MenuItem Style="{StaticResource TopMenuItemStyle}" Header="_정렬/편집">
                <MenuItem Header="되돌리기" InputGestureText="Ctrl+Z" IsEnabled="{Binding CanUndo}" Click="Undo_OnClick" />
                <MenuItem Header="다시하기" InputGestureText="Ctrl+Y" IsEnabled="{Binding CanRedo}" Click="Redo_OnClick" />
                <Separator />
                <MenuItem Header="복사" InputGestureText="Ctrl+C" IsEnabled="{Binding HasSelection}" Click="CopySelection_OnClick" />
                <MenuItem Header="붙여넣기" InputGestureText="Ctrl+V" IsEnabled="{Binding CanPasteSelection}" Click="PasteSelection_OnClick" />
                <Separator />
                <MenuItem Header="앞으로 보내기" IsEnabled="{Binding HasSelection}" Click="BringToFront_OnClick" />
                <MenuItem Header="뒤로 보내기" IsEnabled="{Binding HasSelection}" Click="SendToBack_OnClick" />
                <Separator />
                <MenuItem Header="복제" InputGestureText="Ctrl+D" IsEnabled="{Binding HasSelection}" Click="DuplicateSelected_OnClick" />
                <MenuItem Header="삭제" InputGestureText="Del" IsEnabled="{Binding HasSelection}" Click="DeleteSelected_OnClick" />
            </MenuItem>
            <MenuItem Style="{StaticResource TopMenuItemStyle}" Header="_보기">
                <MenuItem Header="그리드 표시" IsCheckable="True" IsChecked="{Binding ShowGrid, Mode=TwoWay}" />
                <MenuItem Header="격자 스냅" IsCheckable="True" IsChecked="{Binding SnapToGrid, Mode=TwoWay}" />
                <MenuItem Header="정렬 기준선" IsCheckable="True" IsChecked="{Binding ShowGuides, Mode=TwoWay}" />
            </MenuItem>
            <MenuItem Style="{StaticResource TopMenuItemStyle}" Header="_도움말" Click="About_OnClick" />
        </Menu>
        <StatusBar DockPanel.Dock="Bottom" Background="#FFF8EF">
            <StatusBarItem><TextBlock Text="{Binding StatusText}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding SelectedBoard.Title, StringFormat=보드: {0}}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding SelectedCount, StringFormat=선택: {0}개}" /></StatusBarItem>
        </StatusBar>
        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Padding="18" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="#2A2A2A" Text="앱디자이너" />
                        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#645745" Text="새로 만들기 템플릿, 탭 보드, 번호 표기, 참고 이미지 붙여넣기까지 한 번에 쓰는 설계판입니다." />
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="보드 설정" />
                        <TextBlock Foreground="#5C5C5C" Text="현재 탭 제목" />
                        <TextBox Margin="0,6,0,0" Padding="10,8" Text="{Binding SelectedBoard.Title, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                        <CheckBox Margin="0,12,0,0" Content="그리드 표시" IsChecked="{Binding ShowGrid, Mode=TwoWay}" />
                        <CheckBox Margin="0,6,0,0" Content="격자 스냅" IsChecked="{Binding SnapToGrid, Mode=TwoWay}" />
                        <CheckBox Margin="0,6,0,0" Content="정렬 기준선" IsChecked="{Binding ShowGuides, Mode=TwoWay}" />
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="빠른 추가" />
                        <Button Style="{StaticResource QuickAddButtonStyle}" Tag="dialog" Click="AddElementMenuItem_OnClick" Content="1. [창] 대화창 추가&#10;   [제목][내용][버튼]" />
                        <Button Style="{StaticResource QuickAddButtonStyle}" Tag="popup" Click="AddElementMenuItem_OnClick" Content="2. [알림] 작은 알림창 추가&#10;   [안내][확인]" />
                        <Button Style="{StaticResource QuickAddButtonStyle}" Tag="buttons" Click="AddElementMenuItem_OnClick" Content="3. [버튼] 버튼 묶음 추가&#10;   [저장][취소][삭제]" />
                        <Button Style="{StaticResource QuickAddButtonStyle}" Tag="tabs" Click="AddElementMenuItem_OnClick" Content="4. [탭] 탭 화면 추가&#10;   [탭][탭][내용]" />
                        <Button Style="{StaticResource QuickAddButtonStyle}" Tag="form" Click="AddElementMenuItem_OnClick" Content="5. [폼] 입력 폼 추가&#10;   [라벨][입력칸]" />
                        <Button Style="{StaticResource QuickAddButtonStyle}" Tag="section" Click="AddElementMenuItem_OnClick" Content="6. [구역] 화면 구역 추가&#10;   [제목][카드][목록]" />
                        <Button Style="{StaticResource QuickAddButtonStyle}" Tag="hero" Click="AddElementMenuItem_OnClick" Content="7. [랜딩] 랜딩 첫 화면 추가&#10;   [문구][버튼][이미지]" />
                        <Button Style="{StaticResource QuickAddButtonStyle}" Tag="note" Click="AddElementMenuItem_OnClick" Content="8. [메모] 메모 추가&#10;   [지시][주의][할 일]" />
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="사용 팁" />
                        <TextBlock TextWrapping="Wrap" Foreground="#6A5D4D" Text="1. Shift를 누른 채 칸을 클릭하면 여러 개를 함께 선택할 수 있습니다." />
                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#6A5D4D" Text="2. 선택된 칸은 같이 이동되고, 모서리 점을 끌면 같이 크기가 바뀝니다." />
                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#6A5D4D" Text="3. 기준선을 켜면 다른 칸이나 중앙선에 맞춰 정렬하기 쉽습니다." />
                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#6A5D4D" Text="4. Del 삭제, Ctrl+C 복사, Ctrl+V 붙여넣기, Ctrl+Z 되돌리기, Ctrl+Y 다시하기를 쓸 수 있습니다." />
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <Border Grid.Column="1" Margin="18,0" Padding="18" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Vertical">
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="#202020" Text="{Binding SelectedBoard.Title}" />
                            <TextBlock Margin="0,4,0,0" Foreground="#756A5C" Text="1600 x 900 설계 보드 / Shift 다중 선택 / 모서리 리사이즈" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Padding="14,8" Background="#F3EBDE" BorderBrush="#D9C8AE" Click="AddBoardTab_OnClick" Content="+ 탭 추가" />
                    </DockPanel>
                    <TabControl Grid.Row="1" Height="38" Margin="0,0,0,12" ItemsSource="{Binding Boards}" SelectedItem="{Binding SelectedBoard}" BorderThickness="0" Background="Transparent">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="10,4" Text="{Binding Title}" />
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Border Height="0" Background="Transparent" />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                    <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                        <Border Padding="16" Background="#D8CFBF" CornerRadius="24">
                            <Grid x:Name="BoardSurface" Width="1600" Height="900" ClipToBounds="True" MouseLeftButtonDown="BoardSurface_OnMouseLeftButtonDown">
                                <Border x:Name="BoardBackground" CornerRadius="20" Background="{StaticResource BoardGridBrush}" BorderBrush="#E6DCCF" BorderThickness="1" />
                                <Line X1="800" Y1="0" X2="800" Y2="900" Stroke="#BFB1A0" StrokeThickness="1" StrokeDashArray="4,6" Opacity="0.4" IsHitTestVisible="False" Visibility="{Binding ShowGuides, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Line X1="0" Y1="450" X2="1600" Y2="450" Stroke="#BFB1A0" StrokeThickness="1" StrokeDashArray="4,6" Opacity="0.4" IsHitTestVisible="False" Visibility="{Binding ShowGuides, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Line x:Name="VerticalGuideLine" Visibility="Collapsed" Stroke="#D46B2A" StrokeThickness="2" StrokeDashArray="6,4" IsHitTestVisible="False" />
                                <Line x:Name="HorizontalGuideLine" Visibility="Collapsed" Stroke="#D46B2A" StrokeThickness="2" StrokeDashArray="6,4" IsHitTestVisible="False" />
                                <ItemsControl ItemsSource="{Binding CurrentElements}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                            <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                                            <Setter Property="Width" Value="{Binding Width}" />
                                            <Setter Property="Height" Value="{Binding Height}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:DesignElement}">
                                            <Grid>
                                                <Border CornerRadius="18" Background="{Binding FillBrush}" BorderBrush="{Binding BorderBrush}" BorderThickness="2" Padding="16" PreviewMouseLeftButtonDown="DesignItem_OnPreviewMouseLeftButtonDown" PreviewMouseMove="DesignItem_OnPreviewMouseMove" PreviewMouseLeftButtonUp="DesignItem_OnPreviewMouseLeftButtonUp" PreviewMouseRightButtonDown="DesignItem_OnPreviewMouseRightButtonDown">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="복사" InputGestureText="Ctrl+C" Click="CopySelection_OnClick" />
                                                            <MenuItem Header="붙여넣기" InputGestureText="Ctrl+V" Click="PasteSelection_OnClick" />
                                                            <Separator />
                                                            <MenuItem Header="복제" Click="DuplicateSelected_OnClick" />
                                                            <MenuItem Header="삭제" InputGestureText="Del" Click="DeleteSelected_OnClick" />
                                                            <Separator />
                                                            <MenuItem Header="앞으로 보내기" Click="BringToFront_OnClick" />
                                                            <MenuItem Header="뒤로 보내기" Click="SendToBack_OnClick" />
                                                            <Separator />
                                                            <MenuItem Header="되돌리기" InputGestureText="Ctrl+Z" Click="Undo_OnClick" />
                                                            <MenuItem Header="다시하기" InputGestureText="Ctrl+Y" Click="Redo_OnClick" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <DockPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Margin="0,0,8,0" Background="#1F3A5B" CornerRadius="999" Padding="9,4"><TextBlock Foreground="White" FontSize="11" FontWeight="Bold" Text="{Binding MarkerText}" /></Border>
                                                                <Border Background="{Binding AccentBrush}" CornerRadius="999" Padding="10,4"><TextBlock Foreground="White" FontSize="11" FontWeight="Bold" Text="{Binding ElementType}" /></Border>
                                                            </StackPanel>
                                                            <Border DockPanel.Dock="Right" Margin="10,0,0,0" Padding="8,6" Background="#FFFDF9" BorderBrush="#E6D8C3" BorderThickness="1" CornerRadius="10">
                                                                <TextBlock FontSize="10" Foreground="#6D6254" Text="{Binding PreviewText}" TextAlignment="Center" TextWrapping="Wrap" />
                                                            </Border>
                                                        </DockPanel>
                                                        <TextBlock Grid.Row="1" Margin="0,12,0,0" FontSize="18" FontWeight="SemiBold" Foreground="#202020" Text="{Binding Title}" />
                                                        <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="#4E4E4E" Text="{Binding Description}" TextWrapping="Wrap" />
                                                        <DockPanel Grid.Row="3" Margin="0,14,0,0">
                                                            <TextBlock Foreground="#737373" FontSize="11" Text="{Binding PositionText}" />
                                                            <TextBlock DockPanel.Dock="Right" Foreground="#737373" FontSize="11" Text="{Binding SizeText}" />
                                                        </DockPanel>
                                                    </Grid>
                                                </Border>
                                                <Border CornerRadius="18" BorderBrush="#0D7B66" BorderThickness="4" IsHitTestVisible="False" Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <primitives:Thumb HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-7,-7,0,0" Cursor="SizeNWSE" Tag="TopLeft" Style="{StaticResource ResizeThumbStyle}" Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
                                                <primitives:Thumb HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-7,-7,0" Cursor="SizeNESW" Tag="TopRight" Style="{StaticResource ResizeThumbStyle}" Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
                                                <primitives:Thumb HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-7,0,0,-7" Cursor="SizeNESW" Tag="BottomLeft" Style="{StaticResource ResizeThumbStyle}" Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
                                                <primitives:Thumb HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-7,-7" Cursor="SizeNWSE" Tag="BottomRight" Style="{StaticResource ResizeThumbStyle}" Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" DragStarted="ResizeThumb_OnDragStarted" DragDelta="ResizeThumb_OnDragDelta" DragCompleted="ResizeThumb_OnDragCompleted" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Border Grid.Column="2" Padding="18" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="20">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem Header="구성요소">
                        <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="Bold" Foreground="#262626" Text="구성요소" />
                                <TextBlock Margin="0,8,0,0" Foreground="#6D6256" Text="아이콘과 한글 이름을 보고 바로 추가하는 UI 블록 팔레트입니다." />
                                <Border Margin="0,18,0,16" Padding="14" Background="#FFF2EADD" BorderBrush="#E4D6C0" BorderThickness="1" CornerRadius="16">
                                    <TextBlock Foreground="#6B5E4E" TextWrapping="Wrap" Text="카드를 누르면 중앙 보드에 바로 추가됩니다. 같은 종류를 계속 넣고 싶으면 같은 카드를 반복해서 누르면 됩니다." />
                                </Border>
                                <ItemsControl ItemsSource="{Binding PaletteCategories}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:UiComponentCategory}">
                                            <Expander Style="{StaticResource PaletteExpanderStyle}">
                                                <Expander.Header>
                                                    <Border Padding="12,10" Background="#FFF7F0E6" BorderBrush="#E1D5C2" BorderThickness="1" CornerRadius="14">
                                                        <DockPanel>
                                                            <TextBlock FontSize="13" FontWeight="Bold" Foreground="#5B4837" Text="{Binding Name}" />
                                                            <TextBlock DockPanel.Dock="Right" Foreground="#8B7A67" Text="{Binding Items.Count, StringFormat={}{0}개}" />
                                                        </DockPanel>
                                                    </Border>
                                                </Expander.Header>
                                                <Border Margin="0,10,0,0" Background="Transparent">
                                                    <ItemsControl ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type local:UiComponentItem}">
                                                                <Button Style="{StaticResource PaletteCardButtonStyle}" Click="PaletteComponent_OnClick">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="54" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Width="42" Height="42" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FFF7F0E6" BorderBrush="#E0D2BE" BorderThickness="1" CornerRadius="12">
                                                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#5B4837" Text="{Binding IconText}" />
                                                                        </Border>
                                                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#27221D" Text="{Binding Name}" />
                                                                            <TextBlock Margin="0,2,0,0" Foreground="#7A6A58" Text="{Binding DisplayName}" />
                                                                            <TextBlock Margin="0,4,0,0" Foreground="#5F5A54" TextWrapping="Wrap" Text="{Binding Description}" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="속성">
                        <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="Bold" Foreground="#262626" Text="속성" />
                                <TextBlock Margin="0,8,0,0" Foreground="#6D6256" Text="{Binding SelectedElementSummary}" />
                                <Border Margin="0,18,0,0" Padding="14" Background="#FFF2EADD" BorderBrush="#E4D6C0" BorderThickness="1" CornerRadius="16" Visibility="{Binding HasNoSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Foreground="#6B5E4E" TextWrapping="Wrap" Text="보드에서 칸 하나를 클릭하면 여기에서 이름, 설명, 위치, 크기를 바로 바꿀 수 있습니다." />
                                </Border>
                                <Border Margin="0,18,0,0" Padding="14" Background="#FFF2EADD" BorderBrush="#E4D6C0" BorderThickness="1" CornerRadius="16" Visibility="{Binding HasMultipleSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Foreground="#6B5E4E" TextWrapping="Wrap" Text="여러 칸이 선택되어 있습니다. 지금은 함께 이동하고 크기 조절할 수 있고, 개별 이름 편집은 한 칸만 선택했을 때 가능합니다." />
                                </Border>
                                <StackPanel Margin="0,14,0,0" Visibility="{Binding CanEditSingleElement, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="한 칸 상세 편집" />
                                    <TextBlock Foreground="#5C5C5C" Text="구성요소 종류" />
                                    <TextBox Margin="0,6,0,0" Padding="10,8" IsReadOnly="True" Background="#FFF7F2EA" BorderBrush="#E1D4C2" Text="{Binding EditableElement.ElementType, TargetNullValue=''}" />
                                    <TextBlock Margin="0,12,0,0" Foreground="#5C5C5C" Text="이름" />
                                    <TextBox Margin="0,6,0,0" Padding="10,8" Text="{Binding EditableElement.Title, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    <TextBlock Margin="0,12,0,0" Foreground="#5C5C5C" Text="설명" />
                                    <TextBox Margin="0,6,0,0" Height="120" Padding="10,8" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding EditableElement.Description, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="위치와 크기" />
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,8,10"><TextBlock Foreground="#5C5C5C" Text="X" /><TextBox Margin="0,6,0,0" Padding="10,8" Text="{Binding EditableElement.Left, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" /></StackPanel>
                                        <StackPanel Margin="8,0,0,10"><TextBlock Foreground="#5C5C5C" Text="Y" /><TextBox Margin="0,6,0,0" Padding="10,8" Text="{Binding EditableElement.Top, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" /></StackPanel>
                                        <StackPanel Margin="0,0,8,10"><TextBlock Foreground="#5C5C5C" Text="너비" /><TextBox Margin="0,6,0,0" Padding="10,8" Text="{Binding EditableElement.Width, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" /></StackPanel>
                                        <StackPanel Margin="8,0,0,10"><TextBlock Foreground="#5C5C5C" Text="높이" /><TextBox Margin="0,6,0,0" Padding="10,8" Text="{Binding EditableElement.Height, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" /></StackPanel>
                                    </UniformGrid>
                                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="확장 예정" />
                                    <Border Padding="12" Background="#FFFFFBF5" BorderBrush="#E4D6C0" BorderThickness="1" CornerRadius="14">
                                        <TextBlock Foreground="#6B5E4E" TextWrapping="Wrap" Text="색상, 태그, 잠금 여부는 이 자리에서 이어서 추가할 수 있게 구조를 나눠 두었습니다." />
                                    </Border>
                                </StackPanel>
                                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="참고 이미지" />
                                <Border Padding="10" Background="#FFFDF9" BorderBrush="#E4D6C0" BorderThickness="1" CornerRadius="14">
                                    <Grid>
                                        <Image MaxHeight="220" Stretch="Uniform" Source="{Binding CurrentReferenceImage}" Visibility="{Binding HasReferenceImage, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8B7E6D" Text="붙여넣은 참고 이미지가 여기에 보입니다.">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasReferenceImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                                <Button Margin="0,10,0,0" Style="{StaticResource SecondaryToolButtonStyle}" Click="PasteReferenceImage_OnClick" Content="클립보드 이미지 붙여넣기" />
                                <Button Margin="0,10,0,0" Style="{StaticResource SecondaryToolButtonStyle}" Click="GenerateDraftFromClipboard_OnClick" Content="붙여넣은 이미지로 기초 도안 만들기" />
                                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="선택 항목 작업" />
                                <Button Margin="0,0,0,10" Style="{StaticResource SecondaryToolButtonStyle}" IsEnabled="{Binding HasSelection}" Click="DuplicateSelected_OnClick" Content="선택 항목 복제" />
                                <Button Margin="0,0,0,10" Style="{StaticResource SecondaryToolButtonStyle}" IsEnabled="{Binding HasSelection}" Click="BringToFront_OnClick" Content="앞으로 보내기" />
                                <Button Margin="0,0,0,10" Style="{StaticResource SecondaryToolButtonStyle}" IsEnabled="{Binding HasSelection}" Click="SendToBack_OnClick" Content="뒤로 보내기" />
                                <Button Padding="12,10" Background="#F7D9D3" BorderBrush="#DFAAA0" BorderThickness="1" Cursor="Hand" IsEnabled="{Binding HasSelection}" Click="DeleteSelected_OnClick" Content="선택 항목 삭제" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>


